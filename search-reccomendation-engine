  { id: 3, name: "Jaisalmer", state: "Rajasthan", category: "Adventure", season: "Winter", budget: "Mid", family: true, days: 2, popularity: 71, rating: 4.4, tags: ["desert", "camel safari", "fort"] },
  { id: 4, name: "Munnar", state: "Kerala", category: "Hill Station", season: "Winter", budget: "Mid", family: true, days: 4, popularity: 88, rating: 4.6, tags: ["tea gardens", "mist", "trekking"] },
  { id: 5, name: "Alleppey", state: "Kerala", category: "Beach", season: "Winter", budget: "Mid", family: true, days: 2, popularity: 80, rating: 4.5, tags: ["backwaters", "houseboat"] },
